# === Supabase (Project Settings → API) ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role — שרת בלבד, לעולם לא בצד לקוח
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Resend (מיילים מעוצבים) — אופציונלי בשלב פיתוח ===
# בלי מפתח: המערכת תחזיר קישור הזמנה להעתקה ידנית
RESEND_API_KEY=
RESEND_FROM="praxisAI <invites@yourdomain.com>"
