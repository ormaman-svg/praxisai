# === Supabase (Project Settings → API) ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role — שרת בלבד, לעולם לא בצד לקוח
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Resend (מיילים מעוצבים) — אופציונלי בשלב פיתוח ===
# בלי מפתח: המערכת תחזיר קישור הזמנה להעתקה ידנית
RESEND_API_KEY=
RESEND_FROM="praxisAI <invites@yourdomain.com>"

# === Twilio (אימות זהות מטופל ב-SMS בווטסאפ) — חובה לאימות מטופלים ===
# בלי שלושת המשתנים האלה אימות הזהות ב-SMS לא יעבוד והבוט לא ימסור מידע אישי.
# מקור: console.twilio.com → Account Info (SID + Auth Token) → Phone Numbers (From)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
